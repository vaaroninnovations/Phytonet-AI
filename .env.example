# PhytoNet AI — production environment template
# ---------------------------------------------------------------
# QUICK START (zero-touch): the compose file ships with dev-only defaults,
# so `docker compose up -d --build` works on a fresh clone with NO .env.
#
# PRODUCTION: `cp .env.example .env` then edit — you MUST replace at least
# JWT_SECRET, SESSION_SECRET, ADMIN_EMAIL, ADMIN_PASSWORD, CORS_ORIGINS and
# FRONTEND_URL before exposing the app to the internet.
#
# Never commit `.env` — only `.env.example`.
# ---------------------------------------------------------------

# ══════════════════════════════════════════════
# REQUIRED for production (compose has dev-only fallbacks)
# ══════════════════════════════════════════════

# Admin bootstrap account — seeded on first backend boot
ADMIN_EMAIL=admin@phytonet.ai
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Cryptographic secrets — generate with:  openssl rand -hex 48
JWT_SECRET=replace-with-openssl-rand-hex-48
SESSION_SECRET=replace-with-openssl-rand-hex-48

# ══════════════════════════════════════════════
# Public URLs — must match your VPS domain / TLS setup
# ══════════════════════════════════════════════

# Public origin of the frontend (used by backend for OAuth redirects, emails, etc.)
FRONTEND_URL=https://phytonet.example.com

# CRA build-time backend URL. Leave as "" for same-origin (nginx proxies /api).
# Set to https://phytonet.example.com if the frontend and backend share a domain.
REACT_APP_BACKEND_URL=

# CORS — comma-separated origins, or * for open (not recommended in prod).
CORS_ORIGINS=https://phytonet.example.com

# ══════════════════════════════════════════════
# Data layer — defaults work with the compose services
# ══════════════════════════════════════════════
MONGO_URL=mongodb://mongodb:27017
DB_NAME=phytonet
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_CONCURRENCY=2

# ══════════════════════════════════════════════
# Auth gate — ON in production, OFF only for local smoke tests
# ══════════════════════════════════════════════
AUTH_GATE_ENABLED=on

# ══════════════════════════════════════════════
# Google OAuth 2.0 (optional — skip section if unused)
# Console → https://console.cloud.google.com/apis/credentials
# ══════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://phytonet.example.com/auth/google/callback

# ══════════════════════════════════════════════
# LLM providers (only one of the two is needed)
# ══════════════════════════════════════════════
# Groq Cloud — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Emergent Universal LLM key (leave blank if self-hosting outside Emergent)
EMERGENT_LLM_KEY=

# ══════════════════════════════════════════════
# Email (optional — used for password resets, share links)
# ══════════════════════════════════════════════
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@phytonet.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# ══════════════════════════════════════════════
# Host port bindings (edit only if 3000/8001 are taken on the VPS)
# ══════════════════════════════════════════════
FRONTEND_PORT=3000
BACKEND_PORT=8001
